{
  "name": "d20-dice-roller",
  "productName": "D20 Dice Roller",
  "version": "1.0.0",
  "description": "A transparent D20 dice roller overlay for tabletop games",
  "main": ".vite/build/main.cjs",
  "type": "module",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build": "vite build --config vite.main.config.ts && vite build --config vite.preload.config.ts && vite build --config vite.renderer.config.ts",
    "dev": "vite --config vite.renderer.config.ts",
    "clean": "node -e \"const fs=require('fs');['.vite','out'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch(e){}})\"",
    "clean:all": "npm run clean && node -e \"const fs=require('fs');['steam-builds'].forEach(d=>{try{fs.rmSync(d,{recursive:true,force:true})}catch(e){}})\"",
    
    "make:win": "npm run build && electron-forge make --platform=win32 --arch=x64",
    "make:mac": "npm run build && electron-forge make --platform=darwin --arch=universal",
    "make:mac-x64": "npm run build && electron-forge make --platform=darwin --arch=x64",
    "make:mac-arm64": "npm run build && electron-forge make --platform=darwin --arch=arm64",
    "make:linux": "npm run build && electron-forge make --platform=linux --arch=x64",
    "make:all": "npm run make:win && npm run make:mac && npm run make:linux",
    
    "steam:prepare": "npm run clean && npm run build && npm run steam:build-all && npm run steam:organize",
    "steam:build-all": "npm run make:win && npm run make:linux",
    "steam:organize": "node scripts/organize-steam-builds.js",
    
    "quick-installer": "npm run clean && npm run build && npm run make:win",
    "package:win": "electron-forge package --platform=win32 --arch=x64",
    "package:mac": "electron-forge package --platform=darwin --arch=universal",
    "package:linux": "electron-forge package --platform=linux --arch=x64"
  },
  "author": {
    "name": "Vasiliy",
    "email": "your.email@example.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.2.0",
    "@electron-forge/maker-deb": "^7.2.0",
    "@electron-forge/maker-dmg": "^7.2.0",
    "@electron-forge/maker-rpm": "^7.2.0",
    "@electron-forge/maker-squirrel": "^7.2.0",
    "@electron-forge/maker-zip": "^7.2.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.2.0",
    "@electron-forge/plugin-vite": "^7.2.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/three": "^0.183.1",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.24",
    "electron": "^28.0.0",
    "electron-winstaller": "^5.4.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  },
  "dependencies": {
    "@react-three/drei": "^9.92.7",
    "@react-three/fiber": "^8.15.19",
    "framer-motion": "^10.16.16",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.160.0"
  }
}
