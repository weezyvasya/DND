{
  "name": "d20-dice-roller",
  "productName": "D20 Dice Roller",
  "version": "1.0.0",
  "description": "A transparent D20 dice roller overlay for tabletop games",
  "main": ".vite/build/main.cjs",
  "type": "module",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "make:win": "npm run build && electron-forge make --platform=win32 --arch=x64",
    "build": "vite build --config vite.main.config.ts && vite build --config vite.preload.config.ts && vite build --config vite.renderer.config.ts",
    "dev": "vite --config vite.renderer.config.ts",
    "clean": "rmdir /s /q .vite 2>nul && rmdir /s /q out 2>nul",
    "quick-installer": "npm run clean && npm run build && npm run make:win"
  },
  "author": {
    "name": "Василий",
    "email": "your.email@example.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.2.0",
    "@electron-forge/maker-squirrel": "^7.2.0",
    "@electron-forge/maker-zip": "^7.2.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.2.0",
    "@electron-forge/plugin-vite": "^7.2.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.24",
    "electron": "^28.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  },
  "dependencies": {
    "@react-three/drei": "^9.92.7",
    "@react-three/fiber": "^8.15.19",
    "framer-motion": "^10.16.16",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.160.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "asar": true,
        "name": "D20 Dice Roller",
        "executableName": "d20-dice-roller",
        "win32metadata": {
          "CompanyName": "D20 Dice Roller",
          "FileDescription": "Transparent D20 dice roller for tabletop games",
          "ProductName": "D20 Dice Roller"
        }
      },
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "d20_dice_roller",
            "authors": "Василий",
            "noMsi": true
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "win32"
          ]
        }
      ],
      "plugins": [
        {
          "name": "@electron-forge/plugin-vite",
          "config": {
            "build": [
              {
                "entry": "src/main/main.ts",
                "config": "vite.main.config.ts"
              },
              {
                "entry": "src/preload/preload.ts",
                "config": "vite.preload.config.ts"
              }
            ],
            "renderer": [
              {
                "name": "main_window",
                "config": "vite.renderer.config.ts"
              }
            ]
          }
        }
      ]
    }
  }
}
